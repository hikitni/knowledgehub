#!/bin/zsh
set -euo pipefail

ROOT="/Users/your-user/KnowledgeHub"
PYTHON="$ROOT/.venv/bin/python"
KB="$ROOT/.venv/bin/kb"
CONFIG="$ROOT/config/knowledge-bases.yaml"
NOTIFY_SCRIPT="/path/to/notification-script.sh"
LOCK_DIR="$ROOT/run/daily-scan.lock"
LOCK_PID_FILE="$LOCK_DIR/pid"
STALE_LOCK_SECONDS=21600
LAST_SUCCESS_FILE="$ROOT/run/last-successful-daily-scan-date"
REPORT_DIR="$ROOT/logs/reports"
OUTBOX_DIR="$ROOT/logs/outbox"

DRY_RUN=0
FORCE=0
for ARG in "$@"; do
  case "$ARG" in
    --dry-run) DRY_RUN=1 ;;
    --force) FORCE=1 ;;
    *)
      echo "Unknown argument: $ARG" >&2
      exit 2
      ;;
  esac
done

mkdir -p "$ROOT/run" "$ROOT/logs" "$REPORT_DIR" "$OUTBOX_DIR"

TODAY="$(date '+%Y-%m-%d')"
if (( DRY_RUN == 0 && FORCE == 0 )) \
  && [[ -f "$LAST_SUCCESS_FILE" ]] \
  && [[ "$(<"$LAST_SUCCESS_FILE")" == "$TODAY" ]]; then
  echo "KnowledgeHub scan skipped: already completed successfully on $TODAY"
  exit 0
fi

LOCK_OWNED=0
lock_age_seconds() {
  local MODIFIED_AT NOW
  MODIFIED_AT="$(stat -f '%m' "$LOCK_DIR" 2>/dev/null || echo 0)"
  NOW="$(date '+%s')"
  if [[ "$MODIFIED_AT" == <-> ]] && (( MODIFIED_AT > 0 )); then
    echo $((NOW - MODIFIED_AT))
  else
    echo "$STALE_LOCK_SECONDS"
  fi
}

acquire_lock() {
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" > "$LOCK_PID_FILE"
    LOCK_OWNED=1
    return 0
  fi

  local EXISTING_PID=""
  local LOCK_AGE=0
  if [[ -r "$LOCK_PID_FILE" ]]; then
    EXISTING_PID="$(<"$LOCK_PID_FILE")"
  fi

  if [[ "$EXISTING_PID" == <-> ]] && kill -0 "$EXISTING_PID" 2>/dev/null; then
    echo "KnowledgeHub scan skipped: process $EXISTING_PID owns the lock" >&2
    return 6
  fi

  # A newly created lock may briefly exist before its PID file is visible.
  # Only clear a missing/invalid PID lock after the stale threshold.
  if [[ "$EXISTING_PID" != <-> ]]; then
    LOCK_AGE="$(lock_age_seconds)"
    if (( LOCK_AGE < STALE_LOCK_SECONDS )); then
      echo "KnowledgeHub scan skipped: lock has no valid PID but is only ${LOCK_AGE}s old" >&2
      return 6
    fi
  fi

  local STALE_DIR="${LOCK_DIR}.stale.$$.$(date '+%s')"
  if ! mv "$LOCK_DIR" "$STALE_DIR" 2>/dev/null; then
    echo "KnowledgeHub scan skipped: lock changed while checking it" >&2
    return 6
  fi
  rm -rf "$STALE_DIR"

  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    echo "KnowledgeHub scan skipped: another process acquired the lock" >&2
    return 6
  fi
  printf '%s\n' "$$" > "$LOCK_PID_FILE"
  LOCK_OWNED=1
}

cleanup() {
  if (( LOCK_OWNED == 1 )) \
    && [[ -r "$LOCK_PID_FILE" ]] \
    && [[ "$(<"$LOCK_PID_FILE")" == "$$" ]]; then
    rm -f "$LOCK_PID_FILE"
    rmdir "$LOCK_DIR" 2>/dev/null || true
  fi
}
trap cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

if acquire_lock; then
  :
else
  LOCK_EXIT=$?
  exit "$LOCK_EXIT"
fi

START_ISO="$(date '+%Y-%m-%dT%H:%M:%S%z')"
RUN_STAMP="$(date '+%Y-%m-%dT%H%M%S')"
REPORT_PATH="$REPORT_DIR/$RUN_STAMP.json"

if [[ ! -x "$KB" ]]; then
  echo "kb CLI not found or not executable: $KB" >&2
  exit 2
fi

if [[ ! -f "$CONFIG" ]]; then
  echo "KnowledgeHub config not found: $CONFIG" >&2
  exit 2
fi

SCAN_ARGS=(reconcile --all --config "$CONFIG" --report-json "$REPORT_PATH")
if (( DRY_RUN == 1 )); then
  SCAN_ARGS+=(--dry-run)
fi

if "$KB" "${SCAN_ARGS[@]}"; then
  SCAN_EXIT=0
else
  SCAN_EXIT=$?
fi
END_ISO="$(date '+%Y-%m-%dT%H:%M:%S%z')"

FALLBACK_BODY="执行状态：$([[ $SCAN_EXIT -eq 0 ]] && echo success || echo failed)
开始时间：$START_ISO
结束时间：$END_ISO
报告：$REPORT_PATH
说明：扫描未生成可解析的 JSON 报告，请检查日志。"
BODY="$FALLBACK_BODY"

if [[ -f "$REPORT_PATH" && -x "$PYTHON" ]]; then
  if PARSED_BODY="$($PYTHON - "$REPORT_PATH" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))

status = data.get("status", "unknown")
started = data.get("started_at", "-")
completed = data.get("completed_at", "-")
duration = data.get("duration_seconds", "-")

lines = [
    f"执行状态：{status}",
    f"开始时间：{started}",
    f"结束时间：{completed}",
    f"耗时：{duration} 秒",
    f"发现文件：{data.get('discovered_count', 0)}",
    f"新增：{data.get('added_count', 0)}",
    f"更新：{data.get('updated_count', 0)}",
    f"删除：{data.get('deleted_count', 0)}",
    f"未变化：{data.get('unchanged_count', 0)}",
    f"跳过：{data.get('skipped_count', 0)}",
    f"失败：{data.get('error_count', 0)}",
]

per_kb = data.get("knowledge_bases", [])
if per_kb:
    lines.extend(["", "分库统计："])
    for item in per_kb:
        lines.append(
            "- {id}：新增 {added}，更新 {updated}，删除 {deleted}，失败 {errors}".format(
                id=item.get("id", "unknown"),
                added=item.get("added_count", 0),
                updated=item.get("updated_count", 0),
                deleted=item.get("deleted_count", 0),
                errors=item.get("error_count", 0),
            )
        )

errors = data.get("errors", [])
if errors:
    lines.extend(["", "失败文件："])
    for item in errors[:10]:
        lines.append(f"- {item.get('path', '-')}：{item.get('safe_message', 'unknown error')}")

lines.extend(["", f"报告：{path}"])
print("\n".join(lines))
PY
  )"; then
    BODY="$PARSED_BODY"
  else
    echo "Failed to parse scan report: $REPORT_PATH" >&2
  fi
fi

if [[ $SCAN_EXIT -eq 0 ]]; then
  TITLE="KnowledgeHub 每日扫描完成"
else
  TITLE="KnowledgeHub 每日扫描失败"
fi

if (( DRY_RUN == 1 )); then
  echo "[$TITLE]"
  echo "$BODY"
  exit "$SCAN_EXIT"
fi

# Record index success before notification. A notification failure is retried
# through the outbox and must not cause the full index job to run again today.
if [[ $SCAN_EXIT -eq 0 ]]; then
  SUCCESS_TMP="${LAST_SUCCESS_FILE}.tmp.$$"
  printf '%s\n' "$TODAY" > "$SUCCESS_TMP"
  mv "$SUCCESS_TMP" "$LAST_SUCCESS_FILE"
fi

if [[ ! -x "$NOTIFY_SCRIPT" ]]; then
  echo "Lark notify script not found: $NOTIFY_SCRIPT" >&2
  cat > "$OUTBOX_DIR/$RUN_STAMP.txt" <<OUTBOX
$TITLE

$BODY
OUTBOX
  [[ $SCAN_EXIT -eq 0 ]] && exit 7 || exit "$SCAN_EXIT"
fi

NOTIFY_EXIT=1
for ATTEMPT in 1 2 3; do
  if "$NOTIFY_SCRIPT" "$BODY" "$TITLE"; then
    NOTIFY_EXIT=0
    break
  else
    NOTIFY_EXIT=$?
  fi
  sleep $((ATTEMPT * 5))
done

if [[ $NOTIFY_EXIT -ne 0 ]]; then
  cat > "$OUTBOX_DIR/$RUN_STAMP.txt" <<OUTBOX
$TITLE

$BODY
OUTBOX
  echo "Lark notification failed after retries" >&2
  [[ $SCAN_EXIT -eq 0 ]] && exit 7 || exit "$SCAN_EXIT"
fi

exit "$SCAN_EXIT"
